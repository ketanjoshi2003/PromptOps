
.codeEditor {
    background-color: var(--color-bg-secondary);
    padding: var(--spacing-md);
    padding-right: 60px;
    border-radius: 0;
    border: none;
    font-family: var(--font-family-mono, monospace);
    font-size: 0.8rem;
    white-space: pre-wrap;
    word-break: break-word;
    position: relative;
    color: var(--color-text-primary);
    width: 100%;
    box-sizing: border-box;
    resize: none;
    outline: none;
    line-height: 1.5;
    overflow: hidden;
}
